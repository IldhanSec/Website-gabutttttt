# 12. CONTOH PROGRAM LENGKAP

## 🎮 PROGRAM MANAJEMEN DATA MAHASISWA

```c
/**
 * ============================================
 * PROGRAM: SISTEM MANAJEMEN DATA MAHASISWA
 * ============================================
 * Menggabungkan semua konsep:
 * - Array, struct, pointer
 * - Dynamic memory allocation
 * - File I/O
 * - Error handling
 * - String manipulation
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// Struktur data mahasiswa
typedef struct {
    int id;
    char nama[50];
    char nim[15];
    float ipk;
    int aktif;  // 1 = aktif, 0 = tidak
} Mahasiswa;

// Prototipe fungsi
void tambah_mahasiswa(Mahasiswa **mhs, int *jumlah, int *kapasitas);
void tampilkan_semua(Mahasiswa *mhs, int jumlah);
void cari_mahasiswa(Mahasiswa *mhs, int jumlah);
void hapus_mahasiswa(Mahasiswa *mhs, int *jumlah);
void urutkan_mahasiswa(Mahasiswa *mhs, int jumlah);
void statistik_mahasiswa(Mahasiswa *mhs, int jumlah);
void simpan_ke_file(Mahasiswa *mhs, int jumlah);
void baca_dari_file(Mahasiswa **mhs, int *jumlah, int *kapasitas);
void tampilkan_menu();

// Fungsi pembanding untuk sorting
int compare_ipk(const void *a, const void *b) {
    Mahasiswa *m1 = (Mahasiswa*)a;
    Mahasiswa *m2 = (Mahasiswa*)b;
    
    if(m1->ipk < m2->ipk) return 1;
    if(m1->ipk > m2->ipk) return -1;
    return 0;
}

int main() {
    Mahasiswa *daftar_mhs = NULL;
    int jumlah = 0;
    int kapasitas = 0;
    int pilihan;
    
    printf("╔════════════════════════════════╗\n");
    printf("║   SISTEM MANAJEMEN MAHASISWA  ║\n");
    printf("║         Versi 1.0              ║\n");
    printf("╚════════════════════════════════╝\n\n");
    
    // Coba baca dari file
    baca_dari_file(&daftar_mhs, &jumlah, &kapasitas);
    
    do {
        tampilkan_menu();
        printf("Pilihan: ");
        
        // Validasi input menu
        if(scanf("%d", &pilihan) != 1) {
            printf("❌ Input tidak valid!\n");
            while(getchar() != '\n');
            continue;
        }
        while(getchar() != '\n');
        
        switch(pilihan) {
            case 1:
                tambah_mahasiswa(&daftar_mhs, &jumlah, &kapasitas);
                break;
            case 2:
                tampilkan_semua(daftar_mhs, jumlah);
                break;
            case 3:
                cari_mahasiswa(daftar_mhs, jumlah);
                break;
            case 4:
                hapus_mahasiswa(daftar_mhs, &jumlah);
                break;
            case 5:
                urutkan_mahasiswa(daftar_mhs, jumlah);
                break;
            case 6:
                statistik_mahasiswa(daftar_mhs, jumlah);
                break;
            case 7:
                simpan_ke_file(daftar_mhs, jumlah);
                break;
            case 0:
                printf("\nTerima kasih!\n");
                simpan_ke_file(daftar_mhs, jumlah);
                free(daftar_mhs);
                break;
            default:
                printf("❌ Pilihan tidak valid!\n");
        }
        
        printf("\n");
        
    } while(pilihan != 0);
    
    return 0;
}

void tampilkan_menu() {
    printf("\n=== MENU UTAMA ===\n");
    printf("1. Tambah Mahasiswa\n");
    printf("2. Tampilkan Semua\n");
    printf("3. Cari Mahasiswa\n");
    printf("4. Hapus Mahasiswa\n");
    printf("5. Urutkan (by IPK)\n");
    printf("6. Statistik\n");
    printf("7. Simpan ke File\n");
    printf("0. Keluar\n");
}

void tambah_mahasiswa(Mahasiswa **mhs, int *jumlah, int *kapasitas) {
    // Alokasi memori jika perlu
    if(*jumlah >= *kapasitas) {
        *kapasitas = (*kapasitas == 0) ? 5 : *kapasitas * 2;
        *mhs = (Mahasiswa*)realloc(*mhs, *kapasitas * sizeof(Mahasiswa));
        
        if(*mhs == NULL) {
            printf("❌ Gagal alokasi memori!\n");
            return;
        }
    }
    
    Mahasiswa *m = &(*mhs)[*jumlah];
    
    printf("\n=== TAMBAH MAHASISWA ===\n");
    
    m->id = *jumlah + 1;
    
    printf("Nama: ");
    fgets(m->nama, sizeof(m->nama), stdin);
    m->nama[strcspn(m->nama, "\n")] = 0;
    
    printf("NIM: ");
    fgets(m->nim, sizeof(m->nim), stdin);
    m->nim[strcspn(m->nim, "\n")] = 0;
    
    printf("IPK: ");
    char buffer[10];
    fgets(buffer, sizeof(buffer), stdin);
    m->ipk = atof(buffer);
    
    m->aktif = 1;
    
    (*jumlah)++;
    printf("✅ Mahasiswa berhasil ditambahkan!\n");
}

void tampilkan_semua(Mahasiswa *mhs, int jumlah) {
    if(jumlah == 0) {
        printf("Belum ada data mahasiswa.\n");
        return;
    }
    
    printf("\n=== DAFTAR MAHASISWA ===\n");
    printf("+------+--------------------+------------+------+--------+\n");
    printf("| %-4s | %-18s | %-10s | %-4s | %-6s |\n", 
           "ID", "Nama", "NIM", "IPK", "Status");
    printf("+------+--------------------+------------+------+--------+\n");
    
    for(int i = 0; i < jumlah; i++) {
        if(mhs[i].aktif) {
            printf("| %-4d | %-18s | %-10s | %-4.2f | %-6s |\n",
                   mhs[i].id,
                   mhs[i].nama,
                   mhs[i].nim,
                   mhs[i].ipk,
                   mhs[i].aktif ? "Aktif" : "Nonaktif");
        }
    }
    printf("+------+--------------------+------------+------+--------+\n");
}

void cari_mahasiswa(Mahasiswa *mhs, int jumlah) {
    if(jumlah == 0) {
        printf("Belum ada data.\n");
        return;
    }
    
    char keyword[50];
    printf("Masukkan nama/NIM: ");
    fgets(keyword, sizeof(keyword), stdin);
    keyword[strcspn(keyword, "\n")] = 0;
    
    printf("\nHasil pencarian:\n");
    int ditemukan = 0;
    
    for(int i = 0; i < jumlah; i++) {
        if((strstr(mhs[i].nama, keyword) != NULL || 
            strstr(mhs[i].nim, keyword) != NULL) && mhs[i].aktif) {
            printf("ID   : %d\n", mhs[i].id);
            printf("Nama : %s\n", mhs[i].nama);
            printf("NIM  : %s\n", mhs[i].nim);
            printf("IPK  : %.2f\n", mhs[i].ipk);
            printf("-------------------\n");
            ditemukan = 1;
        }
    }
    
    if(!ditemukan) {
        printf("Tidak ditemukan.\n");
    }
}

void hapus_mahasiswa(Mahasiswa *mhs, int *jumlah) {
    if(*jumlah == 0) {
        printf("Belum ada data.\n");
        return;
    }
    
    int id;
    printf("Masukkan ID: ");
    scanf("%d", &id);
    while(getchar() != '\n');
    
    for(int i = 0; i < *jumlah; i++) {
        if(mhs[i].id == id) {
            // Soft delete
            mhs[i].aktif = 0;
            printf("✅ Mahasiswa dinonaktifkan.\n");
            return;
        }
    }
    
    printf("❌ ID tidak ditemukan.\n");
}

void urutkan_mahasiswa(Mahasiswa *mhs, int jumlah) {
    if(jumlah == 0) {
        printf("Belum ada data.\n");
        return;
    }
    
    qsort(mhs, jumlah, sizeof(Mahasiswa), compare_ipk);
    printf("✅ Data diurutkan berdasarkan IPK.\n");
    tampilkan_semua(mhs, jumlah);
}

void statistik_mahasiswa(Mahasiswa *mhs, int jumlah) {
    if(jumlah == 0) {
        printf("Belum ada data.\n");
        return;
    }
    
    int aktif = 0;
    float total_ipk = 0;
    float max_ipk = 0, min_ipk = 4.0;
    char *nama_max = "", *nama_min = "";
    
    for(int i = 0; i < jumlah; i++) {
        if(mhs[i].aktif) {
            aktif++;
            total_ipk += mhs[i].ipk;
            
            if(mhs[i].ipk > max_ipk) {
                max_ipk = mhs[i].ipk;
                nama_max = mhs[i].nama;
            }
            if(mhs[i].ipk < min_ipk) {
                min_ipk = mhs[i].ipk;
                nama_min = mhs[i].nama;
            }
        }
    }
    
    printf("\n=== STATISTIK ===\n");
    printf("Total mahasiswa : %d\n", jumlah);
    printf("Mahasiswa aktif : %d\n", aktif);
    printf("Mahasiswa nonaktif: %d\n", jumlah - aktif);
    
    if(aktif > 0) {
        printf("Rata-rata IPK   : %.2f\n", total_ipk / aktif);
        printf("IPK Tertinggi   : %.2f (%s)\n", max_ipk, nama_max);
        printf("IPK Terendah    : %.2f (%s)\n", min_ipk, nama_min);
    }
}

void simpan_ke_file(Mahasiswa *mhs, int jumlah) {
    FILE *file = fopen("mahasiswa.dat", "wb");
    
    if(file == NULL) {
        printf("❌ Gagal membuka file!\n");
        return;
    }
    
    fwrite(&jumlah, sizeof(int), 1, file);
    fwrite(mhs, sizeof(Mahasiswa), jumlah, file);
    
    fclose(file);
    printf("✅ Data disimpan ke mahasiswa.dat\n");
}

void baca_dari_file(Mahasiswa **mhs, int *jumlah, int *kapasitas) {
    FILE *file = fopen("mahasiswa.dat", "rb");
    
    if(file == NULL) {
        printf("ℹ️ File tidak ditemukan. Memulai dengan data kosong.\n");
        return;
    }
    
    fread(jumlah, sizeof(int), 1, file);
    
    *kapasitas = *jumlah;
    *mhs = (Mahasiswa*)malloc(*kapasitas * sizeof(Mahasiswa));
    
    if(*mhs == NULL) {
        printf("❌ Gagal alokasi memori!\n");
        fclose(file);
        return;
    }
    
    fread(*mhs, sizeof(Mahasiswa), *jumlah, file);
    fclose(file);
    
    printf("✅ Data berhasil dibaca. (%d mahasiswa)\n", *jumlah);
}
```

---

# 📌 RINGKASAN

## ✅ HAL PENTING YANG HARUS DIINGAT:

1. **Selalu inisialisasi variabel** sebelum digunakan
2. **Cek batas array** untuk mencegah buffer overflow
3. **Gunakan fgets()** bukan scanf() untuk string
4. **Buang newline** setelah fgets() dengan strcspn()
5. **Cek hasil malloc()** apakah berhasil
6. **free() memory** yang dialokasi dengan malloc/calloc
7. **Set pointer ke NULL** setelah di-free
8. **Validasi input** sebelum diproses
9. **Gunakan konstanta** untuk nilai tetap
10. **Beri nama variabel** yang jelas dan bermakna

## ❌ YANG TIDAK BOLEH DILAKUKAN:

1. ❌ Menggunakan gets() - Rawan buffer overflow
2. ❌ Mengakses array di luar batas
3. ❌ Menggunakan pointer tanpa inisialisasi
4. ❌ Melupakan null terminator pada string
5. ❌ Membandingkan string dengan == (pakai strcmp!)
6. ❌ Lupa free() memory - Memory leak
7. ❌ Mengakses memory yang sudah di-free - Dangling pointer
8. ❌ Membagi dengan nol
9. ❌ Mengabaikan return value fungsi
10. ❌ Menggunakan scanf("%s") tanpa batasan

