# 9. MEMORY MANAGEMENT

## 💾 MANAJEMEN MEMORI DI C

```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main() {
    /**
     * ============================================
     * MEMORI STATIS vs DINAMIS
     * ============================================
     * 
     * MEMORI STATIS:
     * - Ukuran ditentukan saat kompilasi
     * - Dialokasikan di stack
     * - Otomatis dibebaskan
     * 
     * MEMORI DINAMIS:
     * - Ukuran ditentukan saat runtime
     * - Dialokasikan di heap
     * - HARUS dibebaskan manual (free)
     */
    
    /**
     * ============================================
     * MALLOC() - MEMORY ALLOCATION
     * ============================================
     * Mengalokasikan memori sebesar n byte
     * Nilai awal acak (tidak diinisialisasi)
     */
    printf("=== MALLOC ===\n");
    
    int *arr1 = (int*)malloc(5 * sizeof(int));
    
    if(arr1 == NULL) {
        printf("Alokasi memori gagal!\n");
        return 1;
    }
    
    // Isi array (nilai acak!)
    for(int i = 0; i < 5; i++) {
        printf("arr1[%d] = %d\n", i, arr1[i]);  // Nilai acak!
    }
    
    /**
     * ============================================
     * CALLOC() - CONTIGUOUS ALLOCATION
     * ============================================
     * Mengalokasikan memori + set ke 0
     */
    printf("\n=== CALLOC ===\n");
    
    int *arr2 = (int*)calloc(5, sizeof(int));
    
    if(arr2 == NULL) {
        printf("Alokasi memori gagal!\n");
        free(arr1);
        return 1;
    }
    
    // Isi array (semua 0!)
    for(int i = 0; i < 5; i++) {
        printf("arr2[%d] = %d\n", i, arr2[i]);  // Semua 0
    }
    
    /**
     * ============================================
     * REALLOC() - RE-ALLOCATION
     * ============================================
     * Mengubah ukuran memori yang sudah dialokasi
     */
    printf("\n=== REALLOC ===\n");
    
    arr1 = (int*)realloc(arr1, 10 * sizeof(int));
    
    if(arr1 == NULL) {
        printf("Realokasi gagal!\n");
        free(arr2);
        return 1;
    }
    
    printf("Ukuran baru: 10 integer\n");
    
    /**
     * ============================================
     * FREE() - MEMBEBASKAN MEMORI
     * ============================================
     * WAJIB! Mencegah memory leak
     */
    free(arr1);
    free(arr2);
    
    // Set ke NULL setelah di-free
    arr1 = NULL;
    arr2 = NULL;
    
    printf("\n✅ Memori berhasil dibebaskan\n");
    
    /**
     * ============================================
     * MEMORY LEAK - YANG HARUS DIHINDARI!
     * ============================================
     */
    
    // ❌ CONTOH MEMORY LEAK
    void memory_leak() {
        int *leak = (int*)malloc(100 * sizeof(int));
        // Lupa free() -> memory leak!
    }
    
    // ✅ YANG BENAR
    void no_leak() {
        int *data = (int*)malloc(100 * sizeof(int));
        // Gunakan data...
        free(data);  // Bebaskan setelah selesai
    }
    
    /**
     * ============================================
     * DANGLING POINTER
     * ============================================
     * Pointer yang menunjuk ke memori yang sudah di-free
     */
    int *ptr = (int*)malloc(sizeof(int));
    *ptr = 10;
    free(ptr);
    
    // ❌ JANGAN LAKUKAN!
    // *ptr = 20;  // Undefined behavior! Bisa crash
    
    // ✅ SET KE NULL
    ptr = NULL;  // Aman
    
    return 0;
}
```

