# 11. TIPS DAN TRIK

## 💡 BEST PRACTICES DI C

```c
/**
 * ============================================
 * TIPS 1: SELALU VALIDASI INPUT
 * ============================================
 */
#include <stdio.h>

void tips_validasi_input() {
    int angka;
    char buffer[100];
    
    printf("Masukkan angka: ");
    fgets(buffer, sizeof(buffer), stdin);
    
    // Cek apakah input valid
    char *endptr;
    angka = strtol(buffer, &endptr, 10);
    
    if(*endptr != '\n' && *endptr != '\0') {
        printf("Input tidak valid!\n");
    } else {
        printf("Angka: %d\n", angka);
    }
}

/**
 * ============================================
 * TIPS 2: GUNAKAN FUNGSI AMAN
 * ============================================
 */
void tips_fungsi_aman() {
    char nama[20];
    
    // ❌ TIDAK AMAN
    // gets(nama);  // JANGAN GUNAKAN!
    // scanf("%s", nama);  // Rawan overflow
    
    // ✅ AMAN
    fgets(nama, sizeof(nama), stdin);
    nama[strcspn(nama, "\n")] = 0;  // Buang newline
}

/**
 * ============================================
 * TIPS 3: CEK BATAS ARRAY
 * ============================================
 */
void tips_batas_array() {
    int arr[10];
    
    // ✅ Selalu cek batas
    for(int i = 0; i < 10; i++) {  // Gunakan <, bukan <=
        arr[i] = i;
    }
    
    // ❌ JANGAN
    // for(int i = 0; i <= 10; i++) {  // arr[10] out of bounds!
    //     arr[i] = i;
    // }
}

/**
 * ============================================
 * TIPS 4: SELALU INISIALISASI VARIABEL
 * ============================================
 */
void tips_inisialisasi() {
    // ✅ Inisialisasi langsung
    int angka = 0;
    char huruf = '\0';
    int *ptr = NULL;
    
    // ❌ JANGAN
    // int x;  // Nilai acak!
}

/**
 * ============================================
 * TIPS 5: CEK HASIL MALLOC
 * ============================================
 */
void tips_cek_malloc() {
    int *data = (int*)malloc(100 * sizeof(int));
    
    if(data == NULL) {
        printf("Alokasi memori gagal!\n");
        return;
    }
    
    // Gunakan data...
    
    free(data);
    data = NULL;  // Hindari dangling pointer
}

/**
 * ============================================
 * TIPS 6: DEBUG DENGAN PRINTF
 * ============================================
 */
void tips_debug() {
    int x = 5, y = 10;
    
    printf("DEBUG: x = %d, y = %d\n", x, y);
    
    int hasil = x * y;
    printf("DEBUG: hasil = %d\n", hasil);
}

/**
 * ============================================
 * TIPS 7: GUNAKAN KONSTANTA
 * ============================================
 */
#define MAX_SISWA 100
#define PI 3.14159

const int MAX_UMUR = 17;

/**
 * ============================================
 * TIPS 8: BERI NAMA VARIABEL YANG JELAS
 * ============================================
 */
// ❌ BURUK
int a, b, c;

// ✅ BAIK
int jumlah_siswa;
float rata_rata_nilai;
char nama_mahasiswa[50];
```

