# 4. ARRAY

## 📦 ARRAY 1 DIMENSI

```c
#include <stdio.h>

int main() {
    /**
     * ============================================
     * ARRAY 1 DIMENSI
     * ============================================
     * Array = kumpulan data dengan tipe yang sama
     * Indeks array selalu dimulai dari 0
     * Ukuran array harus diketahui saat kompilasi
     */
    
    // CARA 1: Deklarasi + inisialisasi
    int nilai[5] = {85, 90, 78, 88, 92};
    
    // CARA 2: Deklarasi dulu, isi kemudian
    int angka[3];
    angka[0] = 10;
    angka[1] = 20;
    angka[2] = 30;
    
    // CARA 3: Tanpa ukuran (otomatis)
    int fibo[] = {1, 1, 2, 3, 5, 8, 13};
    int panjang = sizeof(fibo) / sizeof(fibo[0]);
    
    // CARA 4: Sebagian diisi (sisanya 0)
    int zero[10] = {1, 2, 3};  // index 3-9 = 0
    
    // Menampilkan array
    printf("=== ARRAY NILAI ===\n");
    for(int i = 0; i < 5; i++) {
        printf("nilai[%d] = %d\n", i, nilai[i]);
    }
    
    printf("\n=== ARRAY FIBONACCI ===\n");
    for(int i = 0; i < panjang; i++) {
        printf("%d ", fibo[i]);
    }
    printf("\n");
    
    /**
     * ============================================
     * INPUT ARRAY DARI USER
     * ============================================
     */
    int input[5];
    printf("\nMasukkan 5 angka:\n");
    for(int i = 0; i < 5; i++) {
        printf("input[%d] = ", i);
        scanf("%d", &input[i]);
    }
    
    printf("Array yang diinput: ");
    for(int i = 0; i < 5; i++) {
        printf("%d ", input[i]);
    }
    printf("\n");
    
    /**
     * ============================================
     * ARRAY SEBAGAI PARAMETER FUNGSI
     * ============================================
     * Array dikirim sebagai pointer (alamat)
     * Perubahan di fungsi akan mengubah array asli
     */
    
    return 0;
}

// Fungsi dengan parameter array
void cetak_array(int arr[], int n) {
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
}

void double_array(int arr[], int n) {
    for(int i = 0; i < n; i++) {
        arr[i] *= 2;  // Mengubah array asli
    }
}
```

