# 3. OPERATOR

## 🧮 OPERATOR DI C

```c
#include <stdio.h>

int main() {
    /**
     * ============================================
     * 1. OPERATOR ARITMATIKA
     * ============================================
     */
    printf("=== OPERATOR ARITMATIKA ===\n");
    
    int a = 10, b = 3;
    
    printf("%d + %d = %d\n", a, b, a + b);  // Penjumlahan
    printf("%d - %d = %d\n", a, b, a - b);  // Pengurangan
    printf("%d * %d = %d\n", a, b, a * b);  // Perkalian
    printf("%d / %d = %d\n", a, b, a / b);  // Pembagian integer
    printf("%d %% %d = %d\n", a, b, a % b); // Modulus (sisa bagi)
    
    // Pembagian float
    float x = 10.0, y = 3.0;
    printf("%.1f / %.1f = %.2f\n", x, y, x / y);
    
    /**
     * ============================================
     * 2. OPERATOR PENUGASAN
     * ============================================
     */
    printf("\n=== OPERATOR PENUGASAN ===\n");
    
    int c = 10;
    printf("c = %d\n", c);
    
    c += 5;  // c = c + 5
    printf("c += 5  → %d\n", c);
    
    c -= 3;  // c = c - 3
    printf("c -= 3  → %d\n", c);
    
    c *= 2;  // c = c * 2
    printf("c *= 2  → %d\n", c);
    
    c /= 4;  // c = c / 4
    printf("c /= 4  → %d\n", c);
    
    c %= 3;  // c = c % 3
    printf("c %%= 3  → %d\n", c);
    
    /**
     * ============================================
     * 3. OPERATOR INCREMENT/DECREMENT
     * ============================================
     */
    printf("\n=== INCREMENT/DECREMENT ===\n");
    
    int i = 5;
    printf("i = %d\n", i);
    printf("i++ = %d (post-increment)\n", i++);  // Cetak dulu, baru tambah
    printf("Sekarang i = %d\n", i);
    
    i = 5;
    printf("++i = %d (pre-increment)\n", ++i);    // Tambah dulu, baru cetak
    
    /**
     * ============================================
     * 4. OPERATOR PEMBANDING (RELATIONAL)
     * ============================================
     */
    printf("\n=== OPERATOR PEMBANDING ===\n");
    
    int p = 10, q = 20;
    printf("p = %d, q = %d\n", p, q);
    printf("p == q : %d\n", p == q);  // Sama dengan
    printf("p != q : %d\n", p != q);  // Tidak sama
    printf("p < q  : %d\n", p < q);   // Kurang dari
    printf("p > q  : %d\n", p > q);   // Lebih dari
    printf("p <= q : %d\n", p <= q);  // Kurang sama
    printf("p >= q : %d\n", p >= q);  // Lebih sama
    
    /**
     * ============================================
     * 5. OPERATOR LOGIKA
     * ============================================
     */
    printf("\n=== OPERATOR LOGIKA ===\n");
    
    int u = 1, v = 0;
    printf("u = %d, v = %d\n", u, v);
    printf("u && v : %d (AND)\n", u && v);   // Keduanya harus 1
    printf("u || v : %d (OR)\n", u || v);    // Salah satu 1
    printf("!u     : %d (NOT u)\n", !u);     // Kebalikan
    printf("!v     : %d (NOT v)\n", !v);
    
    /**
     * ============================================
     * 6. OPERATOR BITWISE
     * ============================================
     */
    printf("\n=== OPERATOR BITWISE ===\n");
    
    unsigned char m = 5;   // 00000101
    unsigned char n = 3;   // 00000011
    
    printf("m = %d (biner: 00000101)\n", m);
    printf("n = %d (biner: 00000011)\n", n);
    printf("m & n  = %d (AND bitwise)\n", m & n);   // 00000001 = 1
    printf("m | n  = %d (OR bitwise)\n", m | n);    // 00000111 = 7
    printf("m ^ n  = %d (XOR bitwise)\n", m ^ n);   // 00000110 = 6
    printf("~m     = %d (NOT bitwise)\n", (unsigned char)~m);  // 11111010 = 250
    printf("m << 1 = %d (shift kiri)\n", m << 1);   // 00001010 = 10
    printf("m >> 1 = %d (shift kanan)\n", m >> 1);  // 00000010 = 2
    
    /**
     * ============================================
     * 7. OPERATOR SIZEOF
     * ============================================
     */
    printf("\n=== OPERATOR SIZEOF ===\n");
    
    int arr[10];
    printf("sizeof(int)      : %lu byte\n", sizeof(int));
    printf("sizeof(arr)      : %lu byte\n", sizeof(arr));
    printf("Jumlah elemen arr: %lu\n", sizeof(arr) / sizeof(arr[0]));
    
    return 0;
}
```

