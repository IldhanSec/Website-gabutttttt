# 7. STRING

## 📝 STRING DI C

```c
#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    /**
     * ============================================
     * APA ITU STRING?
     * ============================================
     * String = array of char yang diakhiri '\0'
     * '\0' = null terminator (penanda akhir string)
     */
    
    // CARA 1: Inisialisasi langsung
    char str1[] = "Hello";  // Otomatis: {'H','e','l','l','o','\0'}
    
    // CARA 2: Array of char
    char str2[6] = {'H', 'e', 'l', 'l', 'o', '\0'};
    
    // CARA 3: Pointer (read-only)
    char *str3 = "World";
    
    // CARA 4: String kosong
    char str4[50] = "";
    
    printf("str1: %s\n", str1);
    printf("str2: %s\n", str2);
    printf("str3: %s\n", str3);
    
    /**
     * ============================================
     * INPUT STRING
     * ============================================
     */
    char nama[50];
    char alamat[100];
    
    printf("\n=== INPUT STRING ===\n");
    
    // scanf("%s") - hanya baca sampai spasi
    printf("Nama (scanf): ");
    scanf("%s", nama);  // ❌ TIDAK AMAN, rawan buffer overflow
    printf("Halo %s\n", nama);
    
    // Bersihkan buffer
    while(getchar() != '\n');
    
    // fgets() - AMAN, bisa baca spasi
    printf("Alamat (fgets): ");
    fgets(alamat, sizeof(alamat), stdin);
    
    // Hapus newline di akhir
    alamat[strcspn(alamat, "\n")] = 0;
    
    printf("Alamat: %s\n", alamat);
    
    /**
     * ============================================
     * FUNGSI-FUNGSI STRING.H
     * ============================================
     */
    printf("\n=== MANIPULASI STRING ===\n");
    
    char s1[50] = "Belajar ";
    char s2[] = "C Programming";
    char s3[50];
    
    // strlen() - panjang string
    printf("Panjang s1: %lu\n", strlen(s1));
    printf("Panjang s2: %lu\n", strlen(s2));
    
    // strcpy() - copy string
    strcpy(s3, s1);  // s3 = "Belajar "
    printf("s3: %s\n", s3);
    
    // strcat() - gabung string
    strcat(s1, s2);  // s1 = "Belajar C Programming"
    printf("s1 setelah digabung: %s\n", s1);
    
    // strcmp() - bandingkan string
    if(strcmp(s1, s2) == 0) {
        printf("String sama\n");
    } else {
        printf("String berbeda\n");
    }
    
    // strchr() - cari karakter
    char *pos = strchr(s1, 'C');
    if(pos != NULL) {
        printf("Karakter 'C' ditemukan di posisi %ld\n", pos - s1);
    }
    
    // strstr() - cari substring
    pos = strstr(s1, "Program");
    if(pos != NULL) {
        printf("'Program' ditemukan: %s\n", pos);
    }
    
    /**
     * ============================================
     * KONVERSI STRING
     * ============================================
     */
    printf("\n=== KONVERSI STRING ===\n");
    
    char angka_str[] = "123";
    char desimal_str[] = "45.67";
    
    int angka = atoi(angka_str);     // String → int
    double desimal = atof(desimal_str); // String → double
    
    printf("String \"%s\" → int %d\n", angka_str, angka);
    printf("String \"%s\" → double %.2f\n", desimal_str, desimal);
    
    /**
     * ============================================
     * TOKENIZATION (STRTOK)
     * ============================================
     */
    printf("\n=== TOKENIZATION ===\n");
    
    char data[] = "Budi,17,Jakarta,Siswa";
    char *token = strtok(data, ",");
    
    while(token != NULL) {
        printf("Token: %s\n", token);
        token = strtok(NULL, ",");
    }
    
    return 0;
}
```

