# 10. ERROR DAN DEBUGGING

## ⚠️ ERROR YANG SERING TERJADI

```c
#include <stdio.h>
#include <stdlib.h>

/**
 * ============================================
 * 1. SEGMENTATION FAULT (SEGFAULT)
 * ============================================
 * Terjadi saat program mengakses memori yang tidak seharusnya
 */
void contoh_segfault() {
    printf("\n=== CONTOH SEGFAULT ===\n");
    
    // ❌ 1. NULL pointer dereference
    int *ptr = NULL;
    // *ptr = 10;  // SEGFAULT! Jangan jalankan
    
    // ❌ 2. Mengakses di luar array
    int arr[5] = {1,2,3,4,5};
    // arr[10] = 100;  // SEGFAULT! Index tidak valid
    
    // ❌ 3. Menggunakan memory yang sudah di-free
    int *data = (int*)malloc(10 * sizeof(int));
    free(data);
    // data[0] = 5;  // SEGFAULT! Memory sudah dilepas
    
    // ✅ Cara aman
    int *safe = (int*)malloc(sizeof(int));
    if(safe != NULL) {
        *safe = 10;
        printf("Nilai: %d\n", *safe);
        free(safe);
        safe = NULL;
    }
}

/**
 * ============================================
 * 2. BUFFER OVERFLOW
 * ============================================
 * Menulis data melebihi kapasitas array
 */
void contoh_buffer_overflow() {
    printf("\n=== CONTOH BUFFER OVERFLOW ===\n");
    
    // ❌ TIDAK AMAN
    char buffer1[5];
    // strcpy(buffer1, "Ini string panjang");  // OVERFLOW!
    
    // ✅ AMAN dengan fgets
    char buffer2[10];
    printf("Masukkan teks (maks 9 char): ");
    fgets(buffer2, sizeof(buffer2), stdin);
    
    // ✅ AMAN dengan strncpy
    char source[] = "Hello World";
    char dest[10];
    strncpy(dest, source, sizeof(dest) - 1);
    dest[sizeof(dest) - 1] = '\0';  // Pastikan null terminated
}

/**
 * ============================================
 * 3. INTEGER OVERFLOW
 * ============================================
 * Melebihi batas maksimum tipe data
 */
void contoh_integer_overflow() {
    printf("\n=== CONTOH INTEGER OVERFLOW ===\n");
    
    unsigned char uc = 255;
    printf("unsigned char: %d\n", uc);
    uc = uc + 1;
    printf("+1 menjadi: %d (overflow!)\n", uc);
    
    signed char sc = 127;
    printf("signed char: %d\n", sc);
    sc = sc + 1;
    printf("+1 menjadi: %d (overflow ke negatif)\n", sc);
}

/**
 * ============================================
 * 4. DIVISION BY ZERO
 * ============================================
 * Membagi bilangan dengan nol
 */
void contoh_division_by_zero() {
    printf("\n=== CONTOH DIVISION BY ZERO ===\n");
    
    int a = 10, b = 0;
    
    // ❌ JANGAN!
    // int c = a / b;  // ERROR! Program crash
    
    // ✅ Validasi dulu
    if(b != 0) {
        int c = a / b;
        printf("Hasil: %d\n", c);
    } else {
        printf("Error: Pembagian dengan nol!\n");
    }
}

/**
 * ============================================
 * 5. UNINITIALIZED VARIABLE
 * ============================================
 * Menggunakan variabel tanpa inisialisasi
 */
void contoh_uninitialized() {
    printf("\n=== CONTOH UNINITIALIZED ===\n");
    
    // ❌ BELUM DIISI
    int x;
    // printf("%d\n", x);  // Nilai acak! Bisa error
    
    // ✅ Selalu inisialisasi
    int y = 0;
    printf("y = %d\n", y);
}

/**
 * ============================================
 * 6. MEMORY LEAK
 * ============================================
 * Lupa membebaskan memori
 */
void contoh_memory_leak() {
    printf("\n=== CONTOH MEMORY LEAK ===\n");
    
    // ❌ Memory leak
    for(int i = 0; i < 10; i++) {
        int *leak = (int*)malloc(1000 * sizeof(int));
        // Lupa free! Memori habis
    }
    
    // ✅ Bebaskan memori
    for(int i = 0; i < 10; i++) {
        int *data = (int*)malloc(1000 * sizeof(int));
        // Gunakan data...
        free(data);  // Jangan lupa!
    }
}

int main() {
    printf("=== DEMONSTRASI ERROR DAN DEBUGGING ===\n");
    
    contoh_segfault();
    contoh_buffer_overflow();
    contoh_integer_overflow();
    contoh_division_by_zero();
    contoh_uninitialized();
    contoh_memory_leak();
    
    return 0;
}
```

