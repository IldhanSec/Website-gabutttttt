# 2. TIPE DATA

## 📊 TIPE DATA PRIMITIF

```c
#include <stdio.h>
#include <limits.h>
#include <float.h>

int main() {
    /**
     * ============================================
     * TIPE DATA INTEGER (BILANGAN BULAT)
     * ============================================
     */
    
    // char: 1 byte (-128 s/d 127 atau 0 s/d 255)
    char karakter = 'A';        // Untuk karakter
    signed char c_neg = -10;    // Bisa negatif
    unsigned char c_pos = 200;   // Hanya positif (0-255)
    
    // short: 2 byte (-32,768 s/d 32,767)
    short int nilai_short = 1000;
    unsigned short int u_short = 60000;
    
    // int: 4 byte (-2,147,483,648 s/d 2,147,483,647)
    int umur = 17;
    unsigned int positif = 4000000000;
    
    // long: 4/8 byte (tergantung sistem)
    long int populasi = 7800000000;
    long long int sangat_besar = 9223372036854775807;
    
    /**
     * ============================================
     * TIPE DATA FLOAT (BILANGAN DESIMAL)
     * ============================================
     */
    
    // float: 4 byte, presisi 6-7 digit desimal
    float ipk = 3.75f;           // Perlu akhiran f
    
    // double: 8 byte, presisi 15-16 digit desimal
    double phi = 3.141592653589793;
    
    // long double: 10/16 byte, presisi lebih tinggi
    long double sangat_presisi = 3.14159265358979323846L;
    
    /**
     * ============================================
     * TIPE DATA VOID
     * ============================================
     */
    // void: tipe khusus untuk:
    // 1. Fungsi yang tidak return nilai
    // 2. Pointer generic (void*)
    
    /**
     * ============================================
     * MENAMPILKAN UKURAN TIPE DATA
     * ============================================
     */
    printf("=== UKURAN TIPE DATA (dalam byte) ===\n");
    printf("char      : %lu byte\n", sizeof(char));
    printf("short     : %lu byte\n", sizeof(short));
    printf("int       : %lu byte\n", sizeof(int));
    printf("long      : %lu byte\n", sizeof(long));
    printf("long long : %lu byte\n", sizeof(long long));
    printf("float     : %lu byte\n", sizeof(float));
    printf("double    : %lu byte\n", sizeof(double));
    printf("long double: %lu byte\n", sizeof(long double));
    
    /**
     * ============================================
     * BATAS-BATAS TIPE DATA
     * ============================================
     */
    printf("\n=== BATAS TIPE DATA ===\n");
    printf("CHAR_MIN    : %d\n", CHAR_MIN);
    printf("CHAR_MAX    : %d\n", CHAR_MAX);
    printf("INT_MIN     : %d\n", INT_MIN);
    printf("INT_MAX     : %d\n", INT_MAX);
    printf("UINT_MAX    : %u\n", UINT_MAX);
    printf("FLT_MIN     : %e\n", FLT_MIN);
    printf("FLT_MAX     : %e\n", FLT_MAX);
    
    return 0;
}
```

## 📋 TABEL TIPE DATA LENGKAP

| **Tipe** | **Format Specifier** | **Ukuran** | **Range** |
|---------|---------------------|-----------|-----------|
| char | `%c` | 1 byte | -128 s/d 127 |
| unsigned char | `%c` atau `%hhu` | 1 byte | 0 s/d 255 |
| short | `%hd` | 2 byte | -32,768 s/d 32,767 |
| unsigned short | `%hu` | 2 byte | 0 s/d 65,535 |
| int | `%d` | 4 byte | -2,147,483,648 s/d 2,147,483,647 |
| unsigned int | `%u` | 4 byte | 0 s/d 4,294,967,295 |
| long | `%ld` | 4/8 byte | Tergantung sistem |
| long long | `%lld` | 8 byte | -9.2e18 s/d 9.2e18 |
| float | `%f` | 4 byte | 1.2e-38 s/d 3.4e38 |
| double | `%lf` | 8 byte | 2.3e-308 s/d 1.7e308 |
| long double | `%Lf` | 10/16 byte | Lebih besar |

